# E-Commerce Platform - Environment Variables

# ========================================
# DATABASE CONFIGURATION
# ========================================
DATABASE_URL=postgres://ecommerce:ecommerce-dev@localhost:5432/ecommerce
REDIS_URL=redis://localhost:6379
MONGO_URL=mongodb://ecommerce:ecommerce-dev@localhost:27017

# ========================================
# KAFKA CONFIGURATION
# ========================================
KAFKA_BROKERS=localhost:9092

# ========================================
# SERVICE PORT ASSIGNMENTS
# ========================================
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
INVENTORY_SERVICE_PORT=8083
CART_SERVICE_PORT=8084
ORDER_SERVICE_PORT=8085
PAYMENT_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087
SEARCH_SERVICE_PORT=8088
ANALYTICS_SERVICE_PORT=8089

# ========================================
# JWT & SECURITY
# ========================================
JWT_PRIVATE_KEY_PATH=./etc/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=./etc/secrets/jwt_public_key
ACCESS_TOKEN_TTL=900          # 15 minutes (seconds)
REFRESH_TOKEN_TTL=604800      # 7 days (seconds)

# ========================================
# SERVICE ENDPOINTS (FOR GATEWAY)
# ========================================
GATEWAY_USER_SERVICE_URL=http://localhost:8081
GATEWAY_PRODUCT_SERVICE_URL=http://localhost:8082
GATEWAY_INVENTORY_SERVICE_URL=http://localhost:8083
GATEWAY_CART_SERVICE_URL=http://localhost:8084
GATEWAY_ORDER_SERVICE_URL=http://localhost:8085
GATEWAY_PAYMENT_SERVICE_URL=http://localhost:8086
GATEWAY_NOTIFICATION_SERVICE_URL=http://localhost:8087
GATEWAY_SEARCH_SERVICE_URL=http://localhost:8088
GATEWAY_ANALYTICS_SERVICE_URL=http://localhost:8089

# ========================================
# GATEWAY CONFIGURATION
# ========================================
GATEWAY_RATE_LIMIT_PER_MINUTE=1000

# ========================================
# LOGGING & OBSERVABILITY
# ========================================
ENVIRONMENT=development
LOG_LEVEL=debug

# ========================================
# STRIPE (PAYMENT SERVICE)
# ========================================
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ========================================
# EMAIL SERVICE (NOTIFICATION SERVICE)
# ========================================
SENDGRID_API_KEY=sg_your_key_here
SENDGRID_FROM_EMAIL=noreply@ecommerce.example.com

# ========================================
# SMS SERVICE (NOTIFICATION SERVICE)
# ========================================
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+1234567890

# ========================================
# AWS (PRODUCTION ONLY)
# ========================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012

# ========================================
# ELASTICSEARCH
# ========================================
ELASTICSEARCH_URL=http://localhost:9200

# ========================================
# DEVELOPMENT SEEDS
# ========================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123!
